{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "id": "log-session-start",
        "type": "command",
        "command": "powershell -Command \"Add-Content -Path '.github/hooks/agent-session.log' -Value \\\"[$(Get-Date)] Copilot agent session started\\\"\""
      }
    ],
    "preToolUse": [
      {
        "id": "log-tool-usage",
        "type": "command",
        "command": "powershell -Command \"Add-Content -Path '.github/hooks/tool-usage.log' -Value \\\"[$(Get-Date)] Tool execution requested\\\"\""
      }
    ]
  }
}